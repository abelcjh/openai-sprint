OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
DATABASE_PATH=data/invoice_register.db
UPLOAD_DIR=data/uploads

# Email connector: polls PDFs/images/text from an IMAP mailbox.
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=
EMAIL_IMAP_MAILBOX=INBOX
EMAIL_IMAP_SEARCH=UNSEEN
EMAIL_IMAP_LIMIT=5

# WhatsApp connector: inbound webhook endpoint is /webhooks/whatsapp.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_MEDIA_AUTH_TOKEN=
